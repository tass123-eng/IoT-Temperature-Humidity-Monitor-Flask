from flask import Flask
import grovepi
from datetime import datetime

app = Flask(__name__)

dht_sensor = 4
dht_type = 0

@app.route("/temperature")
def temp():

    temp, hum = grovepi.dht(dht_sensor, dht_type)
    return str(temp)

@app.route("/humidity")
def hum():
    temp, hum = grovepi.dht(dht_sensor, dht_type)
    return str(hum)

app.run(host="0.0.0.0", port=5000)
